default: build

_vendor-init:
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	submodule_rel="components/libs/zed_sdk_sys/vendor/zed-c-api"
	submodule_path="$repo_root/$submodule_rel"

	if [[ -f "$submodule_path/CMakeLists.txt" ]]; then
		echo "zed-c-api submodule already initialized"
		exit 0
	fi

	echo "initializing $submodule_rel"
	git -C "$repo_root" submodule update --init --recursive -- "$submodule_rel"
	echo "initialized $submodule_rel"

_require-sdk:
	#!/usr/bin/env bash
	set -euo pipefail

	if [[ -d /usr/local/zed/include && -d /usr/local/zed/lib ]]; then
		exit 0
	fi

	if [[ -d /opt/zed-sdk/include && -d /opt/zed-sdk/lib ]]; then
		exit 0
	fi

	echo "Missing ZED SDK install under /usr/local/zed or /opt/zed-sdk" >&2
	exit 1

build:
	#!/usr/bin/env bash
	set -euo pipefail

	crate_dir="$(cd "{{justfile_directory()}}" && pwd)"

	cargo build --manifest-path "$crate_dir/Cargo.toml" --lib

build-demo: _vendor-init _require-sdk
	#!/usr/bin/env bash
	set -euo pipefail

	crate_dir="$(cd "{{justfile_directory()}}" && pwd)"

	cargo build --manifest-path "$crate_dir/Cargo.toml" --bin zed_lowlevel_demo

demo depth_mode="NEURAL_LIGHT": _vendor-init _require-sdk
	#!/usr/bin/env bash
	set -euo pipefail

	crate_dir="$(cd "{{justfile_directory()}}" && pwd)"

	cargo run --manifest-path "$crate_dir/Cargo.toml" --bin zed_lowlevel_demo -- "{{depth_mode}}"

run-demo: demo
