default: demo

_ffi-vendor-init:
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	just --justfile "$repo_root/components/libs/zed_sdk_sys/justfile" _vendor-init

dag:
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	cd "$repo_root"
	cargo run -p cu29-runtime --bin cu29-rendercfg -- --open components/sources/cu_zed/examples/zed_rerun_demo.ron

build: _ffi-vendor-init
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	cd "$repo_root"
	cargo build -p cu-zed --example zed_rerun_demo --features zed-rerun-demo

check: _ffi-vendor-init
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	cd "$repo_root"
	cargo check -p cu-zed --example zed_rerun_demo --features zed-rerun-demo

demo: _ffi-vendor-init
	#!/usr/bin/env bash
	set -euo pipefail

	repo_root="$(cd "{{justfile_directory()}}/../../.." && pwd)"
	cd "$repo_root"
	cargo run -r -p cu-zed --example zed_rerun_demo --features zed-rerun-demo

run: demo

build-demo: build

run-demo: demo
