package := "cu-remote-debug-session"
debug_base := "copper/examples/cu_remote_debug_session/debug/v1"
log := "logs/cu_remote_debug_session.copper"
replay_log := "logs/cu_remote_debug_session_replay.copper"

default: record

# Record a deterministic baseline log for the remote debug session.
record:
	#!/usr/bin/env bash
	set -euo pipefail
	cargo run -p {{package}} -- record

# Start the remote debug server against the recorded baseline log.
resim-debug debug_base=debug_base log=log replay_log=replay_log: record
	#!/usr/bin/env bash
	set -euo pipefail
	invocation_dir="{{invocation_directory()}}"
	log="{{log}}"
	replay_log="{{replay_log}}"
	if [[ "$log" != /* ]]; then
		log="${invocation_dir}/${log}"
	fi
	if [[ "$replay_log" != /* ]]; then
		replay_log="${invocation_dir}/${replay_log}"
	fi
	RUST_BACKTRACE=1 cargo run -p {{package}} -- resim-debug \
		--debug-base "{{debug_base}}" \
		--log-base "$log" \
		--replay-log-base "$replay_log"

# Run the remote debug API smoke test against the recorded baseline log.
smoke: record
	#!/usr/bin/env bash
	set -euo pipefail
	cargo run -p {{package}} -- smoke

# Run the full end-to-end demo in one command.
demo: smoke
