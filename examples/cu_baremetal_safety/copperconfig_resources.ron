(
    logging: (enable_task_logging: false),
    resources: [
        (
            id: "board",
            provider: "crate::harness::resource_support::BoardBundle",
            config: {
                "tag": "alpha-board",
                "start": 7,
            },
        ),
    ],
    tasks: [
        (
            id: "tick",
            type: "crate::harness::resource_tasks::TickSource",
        ),
        (
            id: "probe",
            type: "crate::harness::resource_tasks::ResourceProbeTask",
            resources: {
                "counter": "board.counter",
                "tag": "board.tag",
            },
        ),
        (
            id: "capture",
            type: "crate::harness::resource_tasks::IntSink",
        ),
    ],
    bridges: [
        (
            id: "tap",
            type: "crate::harness::resource_bridges::ResourceBridge",
            resources: {"tag": "board.tag"},
            channels: [
                Rx(id: "probe_rx"),
                Tx(id: "probe_tx"),
            ],
        ),
    ],
    cnx: [
        (
            src: "tick",
            dst: "probe",
            msg: "i32",
        ),
        (
            src: "probe",
            dst: "tap/probe_tx",
            msg: "i32",
        ),
        (
            src: "tap/probe_rx",
            dst: "capture",
            msg: "i32",
        ),
    ],
)