# Extract CopperLists from the log-only mission log as JSON using the release logreader.
logreader log="logs/parallel_mandelbrot_log_only.copper":
  #!/usr/bin/env bash
  set -euo pipefail
  invocation_dir="{{invocation_directory()}}"
  log="{{log}}"
  if [[ "$log" != /* ]]; then
    log="${invocation_dir}/${log}"
  fi
  cd "{{ROOT}}"
  cargo build -p cu-parallel-mandelbrot --bin cu-parallel-mandelbrot-logreader --release
  "{{ROOT}}/target/release/cu-parallel-mandelbrot-logreader" "$log" extract-copperlists --export-format json

# Run fsck on a Mandelbrot log using the release logreader.
fsck log="logs/parallel_mandelbrot_log_only.copper":
  #!/usr/bin/env bash
  set -euo pipefail
  invocation_dir="{{invocation_directory()}}"
  log="{{log}}"
  if [[ "$log" != /* ]]; then
    log="${invocation_dir}/${log}"
  fi
  cd "{{ROOT}}"
  cargo build -p cu-parallel-mandelbrot --bin cu-parallel-mandelbrot-logreader --release
  "{{ROOT}}/target/release/cu-parallel-mandelbrot-logreader" "$log" fsck
