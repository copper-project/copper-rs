ROOT := `git rev-parse --show-toplevel`

# Run the parallel log-only mission in release mode and time the executable.
default: parallel

# Render the benchmark graph for the selected mission.
dag mission="log_only":
  #!/usr/bin/env bash
  set -euo pipefail
  cd "{{ROOT}}"
  cargo run -p cu29-runtime --bin cu29-rendercfg -- --mission "{{mission}}" --open examples/cu_parallel_mandelbrot/copperconfig.ron

# Run the log-only mission without parallel-rt from the compiled release binary.
serial:
  #!/usr/bin/env bash
  set -euo pipefail
  cd "{{ROOT}}"
  cargo build -p cu-parallel-mandelbrot --bin cu-parallel-mandelbrot --release
  start="$(python3 -c 'import time; print(time.perf_counter())')"
  set +e
  "{{ROOT}}/target/release/cu-parallel-mandelbrot"
  status=$?
  set -e
  end="$(python3 -c 'import time; print(time.perf_counter())')"
  python3 -c 'import sys; start=float(sys.argv[1]); end=float(sys.argv[2]); print(f"serial elapsed_s={end-start:.3f}")' "$start" "$end"
  exit "$status"

# Run the serial release binary in the foreground so the TUI monitor stays interactive.
monitor-serial:
  #!/usr/bin/env bash
  set -euo pipefail
  cd "{{ROOT}}"
  cargo build -p cu-parallel-mandelbrot --bin cu-parallel-mandelbrot --release
  "{{ROOT}}/target/release/cu-parallel-mandelbrot"

# Run the log-only mission with parallel-rt from the compiled release binary.
parallel:
  #!/usr/bin/env bash
  set -euo pipefail
  cd "{{ROOT}}"
  cargo build -p cu-parallel-mandelbrot --bin cu-parallel-mandelbrot --release --features 'cu29/parallel-rt'
  start="$(python3 -c 'import time; print(time.perf_counter())')"
  set +e
  "{{ROOT}}/target/release/cu-parallel-mandelbrot"
  status=$?
  set -e
  end="$(python3 -c 'import time; print(time.perf_counter())')"
  python3 -c 'import sys; start=float(sys.argv[1]); end=float(sys.argv[2]); print(f"parallel elapsed_s={end-start:.3f}")' "$start" "$end"
  exit "$status"

