(
    missions: [
        (id: "OneToMany"),
        (id: "OneToManyBackground"),
        (id: "ManyToOne"),
        (id: "ManyToOneBackground"),
        (id: "ManyToMany"),
        (id: "ManyToManyBackground"),
        (id: "BridgeFanout"),
        (id: "BridgeFanoutBackground"),
    ],
    logging: (
        enable_task_logging: true,
        copperlist_count: 4,
        slab_size_mib: 32,
        section_size_mib: 4,
        keyframe_interval: 2,
    ),
    resources: [
        (
            id: "threadpool",
            provider: "cu29::resource::ThreadPoolBundle",
            config: {
                "threads": 2,
            },
        ),
    ],
    tasks: [
        (
            id: "otm_src",
            type: "tasks::SequenceSrc",
            missions: ["OneToMany", "OneToManyBackground"],
            config: {
                "source_id": 1,
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "otm_left_fg",
            type: "tasks::TransformTask",
            missions: ["OneToMany"],
            config: {
                "stage_id": 11,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "otm_right_fg",
            type: "tasks::TransformTask",
            missions: ["OneToMany"],
            config: {
                "stage_id": 12,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "otm_left_bg",
            type: "tasks::TransformTask",
            missions: ["OneToManyBackground"],
            background: true,
            config: {
                "stage_id": 11,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "otm_right_bg",
            type: "tasks::TransformTask",
            missions: ["OneToManyBackground"],
            background: true,
            config: {
                "stage_id": 12,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "otm_sink",
            type: "tasks::SeqPairSink",
            missions: ["OneToMany", "OneToManyBackground"],
            config: {
                "sink_id": 1,
            },
        ),
        (
            id: "mto_src_a",
            type: "tasks::SequenceSrc",
            missions: ["ManyToOne", "ManyToOneBackground"],
            config: {
                "source_id": 1,
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mto_src_b",
            type: "tasks::SequenceSrc",
            missions: ["ManyToOne", "ManyToOneBackground"],
            config: {
                "source_id": 2,
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mto_join_fg",
            type: "tasks::JoinTask",
            missions: ["ManyToOne"],
            config: {
                "stage_id": 21,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mto_join_bg",
            type: "tasks::JoinTask",
            missions: ["ManyToOneBackground"],
            config: {
                "stage_id": 21,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mto_delay_bg",
            type: "tasks::JoinDelayTask",
            missions: ["ManyToOneBackground"],
            background: true,
            config: {
                "stage_id": 21,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mto_sink",
            type: "tasks::JoinSink",
            missions: ["ManyToOne", "ManyToOneBackground"],
            config: {
                "sink_id": 2,
            },
        ),
        (
            id: "mtm_src_a",
            type: "tasks::SequenceSrc",
            missions: ["ManyToMany", "ManyToManyBackground"],
            config: {
                "source_id": 1,
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_src_b",
            type: "tasks::SequenceSrc",
            missions: ["ManyToMany", "ManyToManyBackground"],
            config: {
                "source_id": 2,
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_join_left_fg",
            type: "tasks::JoinTask",
            missions: ["ManyToMany"],
            config: {
                "stage_id": 31,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_join_right_fg",
            type: "tasks::JoinTask",
            missions: ["ManyToMany"],
            config: {
                "stage_id": 32,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_join_left_bg",
            type: "tasks::JoinTask",
            missions: ["ManyToManyBackground"],
            config: {
                "stage_id": 31,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_join_right_bg",
            type: "tasks::JoinTask",
            missions: ["ManyToManyBackground"],
            config: {
                "stage_id": 32,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_delay_left_bg",
            type: "tasks::JoinDelayTask",
            missions: ["ManyToManyBackground"],
            background: true,
            config: {
                "stage_id": 31,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_delay_right_bg",
            type: "tasks::JoinDelayTask",
            missions: ["ManyToManyBackground"],
            background: true,
            config: {
                "stage_id": 32,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "mtm_sink",
            type: "tasks::JoinPairSink",
            missions: ["ManyToMany", "ManyToManyBackground"],
            config: {
                "sink_id": 3,
            },
        ),
        (
            id: "bridge_task_left_fg",
            type: "tasks::BridgeStampTask",
            missions: ["BridgeFanout"],
            config: {
                "stage_id": 41,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "bridge_task_right_fg",
            type: "tasks::BridgeStampTask",
            missions: ["BridgeFanout"],
            config: {
                "stage_id": 42,
                "logical_delay_ticks": 0,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "bridge_task_left_bg",
            type: "tasks::BridgeStampTask",
            missions: ["BridgeFanoutBackground"],
            background: true,
            config: {
                "stage_id": 41,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
        (
            id: "bridge_task_right_bg",
            type: "tasks::BridgeStampTask",
            missions: ["BridgeFanoutBackground"],
            background: true,
            config: {
                "stage_id": 42,
                "logical_delay_ticks": 20,
                "busy_spin_iters": 0,
            },
        ),
    ],
    bridges: [
        (
            id: "alpha",
            type: "bridges::AlphaBridge",
            missions: ["BridgeFanout", "BridgeFanoutBackground"],
            config: {
                "emit_limit": 64,
                "busy_spin_iters": 0,
            },
            channels: [
                Rx(
                    id: "ingress",
                    route: "alpha/ingress",
                ),
            ],
        ),
        (
            id: "beta",
            type: "bridges::BetaBridge",
            missions: ["BridgeFanout", "BridgeFanoutBackground"],
            channels: [
                Tx(
                    id: "left",
                    route: "beta/left",
                ),
                Tx(
                    id: "right",
                    route: "beta/right",
                ),
            ],
        ),
    ],
    cnx: [
        (
            src: "otm_src",
            dst: "otm_left_fg",
            msg: "SeqPayload",
            missions: ["OneToMany"],
        ),
        (
            src: "otm_src",
            dst: "otm_right_fg",
            msg: "SeqPayload",
            missions: ["OneToMany"],
        ),
        (
            src: "otm_left_fg",
            dst: "otm_sink",
            msg: "SeqPayload",
            missions: ["OneToMany"],
        ),
        (
            src: "otm_right_fg",
            dst: "otm_sink",
            msg: "SeqPayload",
            missions: ["OneToMany"],
        ),
        (
            src: "otm_src",
            dst: "otm_left_bg",
            msg: "SeqPayload",
            missions: ["OneToManyBackground"],
        ),
        (
            src: "otm_src",
            dst: "otm_right_bg",
            msg: "SeqPayload",
            missions: ["OneToManyBackground"],
        ),
        (
            src: "otm_left_bg",
            dst: "otm_sink",
            msg: "SeqPayload",
            missions: ["OneToManyBackground"],
        ),
        (
            src: "otm_right_bg",
            dst: "otm_sink",
            msg: "SeqPayload",
            missions: ["OneToManyBackground"],
        ),
        (
            src: "mto_src_a",
            dst: "mto_join_fg",
            msg: "SeqPayload",
            missions: ["ManyToOne"],
        ),
        (
            src: "mto_src_b",
            dst: "mto_join_fg",
            msg: "SeqPayload",
            missions: ["ManyToOne"],
        ),
        (
            src: "mto_join_fg",
            dst: "mto_sink",
            msg: "JoinPayload",
            missions: ["ManyToOne"],
        ),
        (
            src: "mto_src_a",
            dst: "mto_join_bg",
            msg: "SeqPayload",
            missions: ["ManyToOneBackground"],
        ),
        (
            src: "mto_src_b",
            dst: "mto_join_bg",
            msg: "SeqPayload",
            missions: ["ManyToOneBackground"],
        ),
        (
            src: "mto_join_bg",
            dst: "mto_delay_bg",
            msg: "JoinPayload",
            missions: ["ManyToOneBackground"],
        ),
        (
            src: "mto_delay_bg",
            dst: "mto_sink",
            msg: "JoinPayload",
            missions: ["ManyToOneBackground"],
        ),
        (
            src: "mtm_src_a",
            dst: "mtm_join_left_fg",
            msg: "SeqPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_src_b",
            dst: "mtm_join_left_fg",
            msg: "SeqPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_src_a",
            dst: "mtm_join_right_fg",
            msg: "SeqPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_src_b",
            dst: "mtm_join_right_fg",
            msg: "SeqPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_join_left_fg",
            dst: "mtm_sink",
            msg: "JoinPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_join_right_fg",
            dst: "mtm_sink",
            msg: "JoinPayload",
            missions: ["ManyToMany"],
        ),
        (
            src: "mtm_src_a",
            dst: "mtm_join_left_bg",
            msg: "SeqPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_src_b",
            dst: "mtm_join_left_bg",
            msg: "SeqPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_src_a",
            dst: "mtm_join_right_bg",
            msg: "SeqPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_src_b",
            dst: "mtm_join_right_bg",
            msg: "SeqPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_join_left_bg",
            dst: "mtm_delay_left_bg",
            msg: "JoinPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_join_right_bg",
            dst: "mtm_delay_right_bg",
            msg: "JoinPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_delay_left_bg",
            dst: "mtm_sink",
            msg: "JoinPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "mtm_delay_right_bg",
            dst: "mtm_sink",
            msg: "JoinPayload",
            missions: ["ManyToManyBackground"],
        ),
        (
            src: "alpha/ingress",
            dst: "bridge_task_left_fg",
            msg: "SeqPayload",
            missions: ["BridgeFanout"],
        ),
        (
            src: "alpha/ingress",
            dst: "bridge_task_right_fg",
            msg: "SeqPayload",
            missions: ["BridgeFanout"],
        ),
        (
            src: "bridge_task_left_fg",
            dst: "beta/left",
            msg: "SeqPayload",
            missions: ["BridgeFanout"],
        ),
        (
            src: "bridge_task_right_fg",
            dst: "beta/right",
            msg: "SeqPayload",
            missions: ["BridgeFanout"],
        ),
        (
            src: "alpha/ingress",
            dst: "bridge_task_left_bg",
            msg: "SeqPayload",
            missions: ["BridgeFanoutBackground"],
        ),
        (
            src: "alpha/ingress",
            dst: "bridge_task_right_bg",
            msg: "SeqPayload",
            missions: ["BridgeFanoutBackground"],
        ),
        (
            src: "bridge_task_left_bg",
            dst: "beta/left",
            msg: "SeqPayload",
            missions: ["BridgeFanoutBackground"],
        ),
        (
            src: "bridge_task_right_bg",
            dst: "beta/right",
            msg: "SeqPayload",
            missions: ["BridgeFanoutBackground"],
        ),
    ],
)
