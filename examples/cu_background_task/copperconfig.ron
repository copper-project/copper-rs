(
    runtime: (
        // Pools for background tasks; each can also carry a CPU `affinity:` and a
        // `scheduler:` policy. `background: true` tasks use the "background" pool.
        thread_pools: [
            ( id: "background", threads: 1 ),
            ( id: "slow",       threads: 1 ),
        ],
    ),
    tasks: [
        (
            id: "task0",
            type: "tasks::ExampleSrc",
        ),
        (
            id: "task1",
            type: "tasks::ExampleTask",
            background: true,
            config: {"sleep_duration_ms": 1000},
        ),
        (
            id: "task2",
            type: "tasks::ExampleTask",
            background: (pool: "slow"),
            config: {"sleep_duration_ms": 250},
        ),
    ],
    cnx: [
        (
            src: "task0",
            dst: "task1",
            msg: "i32",
        ),
        (
            src: "task1",
            dst: "task2",
            msg: "i32",
        ),
        (
            src: "task2",
            dst: "__nc__",
            msg: "i32",
        ),
    ],
)
