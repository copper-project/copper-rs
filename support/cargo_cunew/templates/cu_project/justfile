# Project automation helpers.

# Extract the structured log via the log reader.
log:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=logreader --bin {{project-name|kebab_case}}-logreader logs/{{project-name|kebab_case}}.copper extract-text-log target/debug/cu29_log_index

# Extract CopperLists from the log output.
cl:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=logreader --bin {{project-name|kebab_case}}-logreader logs/{{project-name|kebab_case}}.copper extract-copperlists

resim:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=sim-debug --bin {{project-name|kebab_case}}-resim -- \
    --log-base logs/{{project-name|kebab_case}}.copper

resim-debug debug_base="copper/projects/{{project-name|snake_case}}/debug/v1" log="logs/{{project-name|kebab_case}}.copper" replay_log="logs/{{project-name|kebab_case}}_resim.copper":
  #!/usr/bin/env bash
  set -euo pipefail
  invocation_dir="{% raw %}{{invocation_directory()}}{% endraw %}"
  log="{% raw %}{{log}}{% endraw %}"
  replay_log="{% raw %}{{replay_log}}{% endraw %}"
  if [[ "$log" != /* ]]; then
    log="${invocation_dir}/${log}"
  fi
  if [[ "$replay_log" != /* ]]; then
    replay_log="${invocation_dir}/${replay_log}"
  fi
  RUST_BACKTRACE=1 cargo run --features=sim-debug --bin {{project-name|kebab_case}}-resim -- \
    --debug-base "{% raw %}{{debug_base}}{% endraw %}" \
    --log-base "$log" \
    --replay-log-base "$replay_log"

# Render the execution DAG from the app config.
dag:
  #!/usr/bin/env bash
  set -euo pipefail
  {% if copper_source == "local" %}
  cargo run --manifest-path "{{copper_root_path}}/Cargo.toml" -p cu29-runtime --bin cu29-rendercfg -- \
    copperconfig.ron --open
  {% else %}
  renderer="$(command -v cu29-rendercfg || true)"
  if [[ -z "$renderer" ]]; then
    echo "cu29-rendercfg not found on PATH; installing it now..." >&2
    {% if copper_source == "crates.io" %}
    cargo install --locked cu29-runtime --version "{{copper_version}}" --bin cu29-rendercfg
    {% elsif copper_source == "git" %}
    cargo install --locked --git "{{copper_git_url}}" {% if copper_git_branch != "__none__" %}--branch "{{copper_git_branch}}" {% elsif copper_git_tag != "__none__" %}--tag "{{copper_git_tag}}" {% elsif copper_git_rev != "__none__" %}--rev "{{copper_git_rev}}" {% endif %} --bin cu29-rendercfg cu29-runtime
    {% endif %}
    renderer="$(command -v cu29-rendercfg || true)"
    if [[ -z "$renderer" ]]; then
      renderer="${CARGO_HOME:-$HOME/.cargo}/bin/cu29-rendercfg"
    fi
  fi
  [[ -x "$renderer" ]] || { echo "Failed to find cu29-rendercfg after installation." >&2; exit 1; }
  "$renderer" copperconfig.ron --open
  {% endif %}

# Compatibility alias for older template docs.
rcfg: dag
