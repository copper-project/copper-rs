(
    logging: (
        enable_task_logging: true,
        slab_size_mib: 16,
        keyframe_interval: 1,
    ),
    tasks: [
        (
            id: "src",
            type: "CounterSrc",
            run_in_sim: true,
        ),
        (
            id: "planner",
            type: "cu29::AnytimeTask<TestPlanner>",
            config: {"budget_us": 1000},
            run_in_sim: true,
        ),
        (
            id: "sink",
            type: "AnytimeSpySink",
            run_in_sim: true,
        ),
    ],
    cnx: [
        (
            src: "src",
            dst: "planner",
            msg: "CounterMsg",
        ),
        (
            src: "planner",
            dst: "sink",
            msg: "cu29::AnytimeOutput<CounterMsg>",
        ),
    ],
)