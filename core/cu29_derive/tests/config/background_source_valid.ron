(
    resources: [
        (
            id: "threadpool",
            provider: "cu29::resource::ThreadPoolBundle",
            config: {"threads": 1},
        ),
    ],
    tasks: [
        (
            id: "src",
            type: "BackgroundSrc",
            background: true,
        ),
        (id: "sink", type: "Sink"),
    ],
    cnx: [
        (
            src: "src",
            dst: "sink",
            msg: "u32",
        ),
    ],
)