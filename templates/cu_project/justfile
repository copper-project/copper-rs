# Project automation helpers.

# Extract the structured log via the log reader.
log:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=logreader --bin {{project-name|kebab_case}}-logreader logs/{{project-name|kebab_case}}.copper extract-text-log target/debug/cu29_log_index

# Extract CopperLists from the log output.
cl:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=logreader --bin {{project-name|kebab_case}}-logreader logs/{{project-name|kebab_case}}.copper extract-copperlists

resim:
  #!/usr/bin/env bash
  set -euo pipefail
  RUST_BACKTRACE=1 cargo run --features=sim-debug --bin {{project-name|kebab_case}}-resim -- \
    --log-base logs/{{project-name|kebab_case}}.copper

resim-debug debug_base="copper/projects/{{project-name|snake_case}}/debug/v1" log="logs/{{project-name|kebab_case}}.copper" replay_log="logs/{{project-name|kebab_case}}_resim.copper":
  #!/usr/bin/env bash
  set -euo pipefail
  invocation_dir="{{invocation_directory()}}"
  log="{{log}}"
  replay_log="{{replay_log}}"
  if [[ "$log" != /* ]]; then
    log="${invocation_dir}/${log}"
  fi
  if [[ "$replay_log" != /* ]]; then
    replay_log="${invocation_dir}/${replay_log}"
  fi
  RUST_BACKTRACE=1 cargo run --features=sim-debug --bin {{project-name|kebab_case}}-resim -- \
    --debug-base "{{debug_base}}" \
    --log-base "$log" \
    --replay-log-base "$replay_log"

# Render the execution DAG from the app config.
rcfg:
  #!/usr/bin/env bash
  set -euo pipefail
  {{copper_root_path}}/target/debug/cu29-rendercfg copperconfig.ron --open
